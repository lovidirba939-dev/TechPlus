# ============================================================
#  TechPlus Server — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas (use SRV format for Render)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/techplus?retryWrites=true&w=majority&appName=TechPlus

# JWT (use long random strings — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_another_64_char_random_string

# Gmail SMTP (use App Password from myaccount.google.com/apppasswords)
EMAIL=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# Free Render blocks direct SMTP ports. In production, set these so Render sends
# email requests over HTTPS to the Vercel serverless relay in client/api/send-email.js.
EMAIL_RELAY_URL=https://your-vercel-app.vercel.app/api/send-email
EMAIL_RELAY_SECRET=replace_with_long_random_secret_optional
EMAIL_TIMEOUT_MS=25000
EMAIL_STRATEGY_TIMEOUT_MS=20000

# Optional: Brevo transactional email (alternative to Gmail SMTP)
# BREVO_API_KEY=your_brevo_api_key
# EMAIL_FROM=your_verified_sender@domain.com
# EMAIL_PROVIDER=auto

# Frontend URL — set to your Vercel deployment URL in production
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Allow Vercel preview/live domains in production CORS checks
ALLOW_VERCEL_PREVIEW_ORIGINS=true

# News APIs (optional but recommended)
NEWSAPI_KEY=your_newsapi_org_key
GNEWS_API_KEY=your_gnews_io_key

# Cookie settings
# Use "none" in production (Vercel frontend + Render backend cross-domain)
# Use "lax" in development (localhost)
COOKIE_SAME_SITE=lax

# Static file serving — keep false when deploying frontend to Vercel separately
SERVE_STATIC=false

# Enable data seeding on startup (set to true on production)
ENABLE_STARTUP_WARMUPS=false
