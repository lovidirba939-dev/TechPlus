# ============================================================
#  TechPlus Client — Environment Variables
#  Copy to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# Backend API URL
# Development: http://localhost:5000
# Production:  your Render service URL (e.g. https://techplus-backend.onrender.com)
VITE_API_URL=http://localhost:5000

# Optional production fallback for free Render backend
# If VITE_API_URL is not set in Vercel, client will try this URL.
VITE_RENDER_API_URL=https://techplus-backend.onrender.com

# Keep false for Vercel + Render split deployment.
# Set true only if frontend and backend are served from same domain with /api proxy.
VITE_USE_SAME_ORIGIN_API=false
